# Database Configuration
DATABASE_URL="postgresql://vlagalabs:vlagalabs_password@localhost:5432/vlagalabs"

# PostgreSQL Configuration (for Docker)
POSTGRES_USER=vlagalabs
POSTGRES_PASSWORD=vlagalabs_password
POSTGRES_DB=vlagalabs

# Payload CMS Configuration
PAYLOAD_SECRET=your-super-secret-key-change-in-production

# Next.js Configuration
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# NextAuth Configuration (if using)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key

# AWS S3 Configuration (optional, for remote media storage)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_BUCKET=your-bucket-name
